// Discover local Docker containers and look for log files
discovery.docker "local_containers" {
  host = "unix:///var/run/docker.sock"
}

// Read the log entries from those discovered containers
local.file_match "docker_logs" {
  path_targets = discovery.docker.local_containers.targets
}

// Stream those logs directly into your Loki instance
loki.write "local_loki" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
